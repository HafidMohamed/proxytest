# ── Server ────────────────────────────────────────────────────────────────────
OUR_SERVER_IP=204.168.150.79
CERTBOT_EMAIL=info@cafezisimoukreuzau.de

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://proxy_user:proxy_pass@postgres/translation_proxy

# ── Security ──────────────────────────────────────────────────────────────────
# IMPORTANT: replace with a real secret:
# python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME_generate_a_real_secret_key_here

# Comma-separated origins allowed to call the API (your dashboard URL)
ALLOWED_ORIGINS_STR=http://localhost:3000,https://cafezisimoukreuzau.de

# ── Translation ───────────────────────────────────────────────────────────────
# Free DeepL key ends with ":fx"  → api-free.deepl.com
# Pro  DeepL key does NOT end ":fx" → api.deepl.com
DEEPL_API_KEY=your-deepl-api-key-here
TARGET_LANG=DE
WORKER_PORT=8001

# ── CDN / Object Storage (optional — leave CDN_BACKEND=db for now) ────────────
CDN_BACKEND=db
CDN_BUCKET=
CDN_REGION=eu-central-1
CDN_ACCESS_KEY=
CDN_SECRET_KEY=
CDN_ENDPOINT_URL=
CDN_PUBLIC_BASE_URL=
