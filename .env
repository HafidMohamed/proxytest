# ── Server ────────────────────────────────────────────────────────────────
OUR_SERVER_IP=204.168.150.79
CERTBOT_EMAIL=info@cafezisimoukreuzau.de

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://proxy_user:proxy_pass@postgres/translation_proxy

# ── Security ──────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_generate_a_real_secret_key_here

# ── CORS (your dashboard origin) ─────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://cafezisimoukreuzau.de

# ── Translation ───────────────────────────────────────────────────────────
# Free DeepL key ends with ":fx" → uses api-free.deepl.com
# Pro key does NOT end with ":fx" → uses api.deepl.com
DEEPL_API_KEY=your-deepl-api-key-here
TARGET_LANG=DE
WORKER_PORT=8001

# ── CDN / Object Storage (optional) ──────────────────────────────────────
# Set CDN_BACKEND=s3 to store translated HTML in S3/Cloudflare R2 instead of DB
CDN_BACKEND=db
CDN_BUCKET=
CDN_REGION=eu-central-1
CDN_ACCESS_KEY=
CDN_SECRET_KEY=
CDN_ENDPOINT_URL=
CDN_PUBLIC_BASE_URL=

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME_generate_with_python_secrets_token_urlsafe_32
ALLOWED_ORIGINS_STR=http://localhost:3000,https://dashboard.yourdomain.com

# ── CDN / S3 (optional — leave CDN_BACKEND=db for local dev) ─────────────────
CDN_BACKEND=db
CDN_BUCKET=
CDN_REGION=eu-central-1
CDN_ACCESS_KEY=
CDN_SECRET_KEY=
CDN_ENDPOINT_URL=
CDN_PUBLIC_BASE_URL=
